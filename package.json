{
  "name": "accessibility-scanner",
  "version": "0.0.2",
  "type": "module",
  "license": "MIT",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "tsx ./src/entries/scan.ts",
    "start:full": "tsx ./src/entries/scan.ts --full",
    "start:accessibility": "tsx ./src/entries/scan.ts --analyzer accessibility",
    "start:seo": "tsx ./src/entries/scan.ts --analyzer seo",
    "start:mobile": "tsx ./src/entries/scan.ts --analyzer mobile",
    "start:ssl": "tsx ./src/entries/scan.ts --analyzer ssl",
    "start:performance": "tsx ./src/entries/scan.ts --analyzer performance",
    "report": "tsx ./src/entries/report.ts",
    "lint": "eslint ./src --ext .ts"
  },
  "devDependencies": {
    "@types/clear": "^0.1.4",
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "axe-core": "^4.11.2",
    "chalk": "^5.6.2",
    "clear": "^0.1.0",
    "dotenv": "^17.4.0",
    "nano": "^10.1.4",
    "md-to-pdf": "^5.2.5",
    "playwright": "^1.59.1",
    "uuid": "^13.0.0"
  }
}
